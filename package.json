{
  "name": "mde",
  "private": true,
  "version": "5.0.0",
  "description": "Deutschsprachiger Markdown Editor als Web- und Electron-App.",
  "author": "Thomas Lauer",
  "type": "module",
  "main": "electron/main.cjs",
  "scripts": {
    "dev": "vite",
    "build": "tsc --noEmit && vite build",
    "build:electron": "tsc --noEmit && cross-env ELECTRON_BUILD=true vite build",
    "electron:dev": "concurrently -k \"vite --host 127.0.0.1 --port 5173\" \"wait-on http://127.0.0.1:5173/mdE/ && cross-env VITE_DEV_SERVER_URL=http://127.0.0.1:5173/mdE/ electron .\"",
    "electron:pack": "npm run build:electron && electron-builder --win --dir",
    "electron:dist": "npm run build:electron && electron-builder --win",
    "preview": "vite preview"
  },
  "dependencies": {
    "dompurify": "^3.2.6",
    "lucide-react": "^0.468.0",
    "marked": "^18.0.5",
    "react": "^18.3.1",
    "react-dom": "^18.3.1"
  },
  "devDependencies": {
    "@types/dompurify": "^3.0.5",
    "@types/node": "^25.9.3",
    "@types/react": "^18.3.12",
    "@types/react-dom": "^18.3.1",
    "@vitejs/plugin-react": "^6.0.2",
    "concurrently": "^10.0.3",
    "cross-env": "^10.1.0",
    "electron": "^39.8.5",
    "electron-builder": "^26.15.3",
    "typescript": "^5.9.3",
    "vite": "^8.0.16",
    "wait-on": "^9.0.10"
  },
  "build": {
    "appId": "de.tlds.mde",
    "productName": "mdE",
    "directories": {
      "output": "release"
    },
    "files": [
      "dist/**/*",
      "electron/**/*",
      "package.json"
    ],
    "win": {
      "target": [
        "nsis",
        "portable"
      ]
    },
    "nsis": {
      "artifactName": "mdE Setup.${ext}",
      "oneClick": false,
      "allowToChangeInstallationDirectory": true
    },
    "portable": {
      "artifactName": "mdE.${ext}"
    },
    "electronDist": "node_modules/electron/dist"
  }
}
